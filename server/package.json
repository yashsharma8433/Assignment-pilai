{
  "name": "sms-server",
  "version": "1.0.0",
  "description": "Student Management System — Fastify API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx --env-file=.env src/db/migrate.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "dotenv": "^16.4.5",
    "pg": "^8.12.0",
    "pino-pretty": "^11.2.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
